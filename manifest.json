{
  "name": "Distill Voice",
  "short_name": "Distill Voice",
  "description": "Transkription & KI-Zusammenfassungen",
  "start_url": "/Transkriptions-Dashboard-Cloud/",
  "display": "standalone",
  "background_color": "#0f1117",
  "theme_color": "#6c63ff",
  "icons": [
    { "src": "img/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "img/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "share_target": {
    "action": "/Transkriptions-Dashboard-Cloud/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "files",
          "accept": ["audio/mpeg", "audio/mp4", "audio/m4a", ".mp3", ".m4a", "text/plain", ".txt"]
        }
      ]
    }
  }
}
